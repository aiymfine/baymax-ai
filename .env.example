# Baymax — Your Personal AI Companion

# ── Ollama ──────────────────────────────────────────
# Ollama must be running locally (default port)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Server ────────────────────────────────────────────
PORT=3200
DATA_DIR=./data

# ── Security (optional) ───────────────────────────────
# Set to enable API authentication (Bearer token)
# API_KEY=your-secret-key

# ── CORS ─────────────────────────────────────────────
# Comma-separated origins (default: allow all for development)
# CORS_ORIGINS=http://localhost:8081,exp://localhost:8081
